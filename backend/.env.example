# Connection string for the Postgres database.
# Local/docker-compose default shown below — change for your deployment.
DATABASE_URL=postgresql+psycopg2://inventory_user:inventory_pass@db:5432/inventory_db

# Comma-separated list of origins allowed to call this API, e.g.
# FRONTEND_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173
# Use "*" only for local development.
FRONTEND_ORIGIN=*
