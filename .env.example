# Used by docker-compose.yml. Copy this file to .env before running
# `docker compose up` and adjust values as needed.

POSTGRES_USER=inventory_user
POSTGRES_PASSWORD=inventory_pass
POSTGRES_DB=inventory_db

# Origins allowed to call the backend API. Use "*" for local use only.
FRONTEND_ORIGIN=*

# URL the BROWSER will use to reach the backend (not a Docker-internal
# hostname — this is baked into the frontend container's served config.js).
# http://localhost:8000 is correct when running docker-compose on your own
# machine with the default port mapping below.
API_URL=http://localhost:8000
